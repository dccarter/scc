/*
 * The purpose of this file is to demonstrate generating symbol only content
 */

#pragma symbol skip
#pragma symbol ignore

#pragma native
#define var(x) s::_##x
#define prop(x, v) ::var(x) = v
#pragma endnative

#pragma native[cpp]
namespace demo {
    void dummyDemo() {
        // just for demonstration purposes
    }
}
#pragma endnative
